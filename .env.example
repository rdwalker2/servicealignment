# ============================================================
# Environment Variables — Sales Command Center
# Copy this file to .env and fill in real values
# NEVER commit .env to version control
# ============================================================

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Salesloft (server-side only — no VITE_ prefix)
SALESLOFT_API_KEY=your-salesloft-api-key-here

# Auth mode: 'dev' = instant login (no email), 'magic_link' = real Supabase Auth
# Remove this line or set to 'magic_link' for production
VITE_AUTH_MODE=dev

# Google Calendar OAuth (server-side only)
GOOGLE_CALENDAR_CLIENT_ID=your-google-client-id-here
GOOGLE_CALENDAR_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_CALENDAR_REDIRECT_URI=https://teamtailor-gtm-workspace-production.up.railway.app/api/google-calendar/callback
